# ── Data source toggle ───────────────────────────────────────────────
# Unset (or anything != "real") => mock generator (default, no DB needed).
# "real" => query Cloudflare D1.
# DATA_SOURCE=real

# ── Cloudflare D1 (only needed when DATA_SOURCE=real / running migrations)
# Used by drizzle-kit (d1-http driver) for migrations from outside Workers.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=

# ── Admin auth ───────────────────────────────────────────────────────
# Secret for signing admin sessions/JWT (generate a random value).
# AUTH_SECRET=

# ── Demo mode ────────────────────────────────────────────────────────
# Sample credentials shown on the LIFF verify screen (fake, safe to be public).
# NEXT_PUBLIC_DEMO_PHONE=0812345678
# NEXT_PUBLIC_DEMO_CODE=DEMO01
